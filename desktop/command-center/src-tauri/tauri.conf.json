{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawOS Command Center",
  "version": "0.1.0",
  "identifier": "io.clawos.command-center",
  "build": {
    "beforeDevCommand": "npm --prefix ../../dashboard/frontend run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "npm --prefix ../../dashboard/frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../services/dashd/static"
  },
  "app": {
    "windows": [
      {
        "title": "ClawOS Command Center",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  }
}
