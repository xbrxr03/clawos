[Unit]
Description=ClawOS toolbridge — Tool Execution Layer
After=clawos-policyd.service clawos-memd.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m services.toolbridge.service
WorkingDirectory=/opt/clawos
Restart=always
RestartSec=3
Environment=PYTHONPATH=/opt/clawos

[Install]
WantedBy=default.target
