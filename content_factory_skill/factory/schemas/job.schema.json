{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "factory/job.schema.json",
  "title": "FactoryJob",
  "description": "Single source of truth for a content factory job.",
  "type": "object",
  "required": [
    "job_id",
    "topic",
    "status",
    "phase",
    "priority",
    "retry_count",
    "max_retries",
    "assigned_agent",
    "lease",
    "created_at",
    "updated_at",
    "artifacts",
    "events",
    "metrics",
    "errors",
    "template",
    "pipeline_config"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^job_\\d{14}_[a-f0-9]{6}$",
      "description": "Unique job identifier. Format: job_YYYYMMDDHHMMSS_xxxxxx",
      "example": "job_20240315100000_a1b2c3"
    },
    "topic": {
      "type": "string",
      "minLength": 1,
      "description": "The input topic or idea to produce content about.",
      "example": "The history of the transistor"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "complete",
        "failed"
      ],
      "description": "Coarse lifecycle state. Drives which queue dir the job lives in."
    },
    "phase": {
      "type": "string",
      "enum": [
        "created",
        "writing",
        "visualizing",
        "voice",
        "assembling",
        "complete",
        "failed"
      ],
      "description": "Current pipeline phase. Determines which agent should handle the job next."
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 5,
      "description": "Scheduling priority. Higher = scheduled first. 1=lowest, 10=highest."
    },
    "template": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional pipeline template name (educational_video, short_form_video, tutorial_video). Determines script style, shot count, visual dimensions, and voice model.",
      "enum": [
        "educational_video",
        "short_form_video",
        "tutorial_video",
        null
      ]
    },
    "pipeline_config": {
      "type": [
        "object",
        "null"
      ],
      "description": "Pipeline configuration block loaded from the named template, or overridden directly. Read by writer_agent (script), visual_agent (visuals), voice_agent (voice).",
      "properties": {
        "script": {
          "type": "object"
        },
        "visuals": {
          "type": "object"
        },
        "voice": {
          "type": "object"
        }
      }
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of times this job has been retried after a lease expiry or error."
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "default": 3,
      "description": "Maximum retries before the job is permanently failed."
    },
    "assigned_agent": {
      "type": [
        "string",
        "null"
      ],
      "description": "agent_id of the agent currently holding the lease. Null when idle.",
      "example": "writer_agent"
    },
    "lease": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "job_id",
            "agent_id",
            "phase",
            "lease_start",
            "lease_expiration"
          ],
          "properties": {
            "job_id": {
              "type": "string"
            },
            "agent_id": {
              "type": "string"
            },
            "phase": {
              "type": "string"
            },
            "lease_start": {
              "type": "string",
              "format": "date-time"
            },
            "lease_expiration": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ],
      "description": "Active lease token issued by the foreman. Null when no lease is held."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the job was first created."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of the last write to this file."
    },
    "artifacts": {
      "type": "object",
      "description": "Absolute paths to each output artifact. Null until the producing phase completes.",
      "properties": {
        "script": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to script.txt"
        },
        "metadata": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to metadata.json (title, tags, description, duration estimate)"
        },
        "shots": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to shots.json"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Paths to image_NN.png files"
        },
        "thumbnail": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to thumbnail.png"
        },
        "voice": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to voice.wav"
        },
        "edit_plan": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to edit_plan.json"
        }
      }
    },
    "events": {
      "type": "array",
      "description": "Snapshot of key events for this job (also written to events.jsonl).",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "agent_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "phase": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Per-phase wall-clock durations in seconds.",
      "properties": {
        "writing_duration_s": {
          "type": [
            "number",
            "null"
          ]
        },
        "visualizing_duration_s": {
          "type": [
            "number",
            "null"
          ]
        },
        "voice_duration_s": {
          "type": [
            "number",
            "null"
          ]
        },
        "assembling_duration_s": {
          "type": [
            "number",
            "null"
          ]
        },
        "total_duration_s": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "errors": {
      "type": "array",
      "description": "Timestamped error records appended on each failure.",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "job_id": "job_20240315100000_a1b2c3",
      "topic": "The history of the transistor",
      "status": "active",
      "phase": "writing",
      "priority": 5,
      "retry_count": 0,
      "max_retries": 3,
      "assigned_agent": "writer_agent",
      "lease": {
        "job_id": "job_20240315100000_a1b2c3",
        "agent_id": "writer_agent",
        "phase": "writing",
        "lease_start": "2024-03-15T10:00:00Z",
        "lease_expiration": "2024-03-15T10:05:00Z"
      },
      "created_at": "2024-03-15T09:59:50Z",
      "updated_at": "2024-03-15T10:00:00Z",
      "artifacts": {
        "script": null,
        "metadata": null,
        "shots": null,
        "images": [],
        "thumbnail": null,
        "voice": null,
        "edit_plan": null
      },
      "events": [],
      "metrics": {
        "writing_duration_s": null,
        "visualizing_duration_s": null,
        "voice_duration_s": null,
        "assembling_duration_s": null,
        "total_duration_s": null
      },
      "errors": [],
      "template": null,
      "pipeline_config": null
    }
  ]
}