[Unit]
Description=ClawOS metricd — OTel token tracking and budget enforcement
After=network.target clawos-policyd.service
Requires=clawos-policyd.service

[Service]
Type=simple
ExecStart=/usr/bin/env python3 -m services.metricd.main
WorkingDirectory=%h/.clawos-runtime
Environment=PYTHONPATH=%h/.clawos-runtime
Restart=always
RestartSec=3

[Install]
WantedBy=clawos.target
