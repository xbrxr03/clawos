[Unit]
Description=ClawOS — Agent-Native AI Stack
Documentation=https://github.com/xbrxr03/clawos
After=network.target

[Service]
Type=simple
ExecStart=%h/clawos/venv/bin/python3 %h/clawos/clients/daemon/daemon.py
Restart=on-failure
RestartSec=5
StandardOutput=append:%h/clawos/logs/clawosd.log
StandardError=append:%h/clawos/logs/clawosd.log
Environment=PYTHONPATH=%h/clawos
Environment=CLAWOS_HOME=%h/clawos
Environment=OLLAMA_HOST=http://localhost:11434
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin"

[Install]
WantedBy=default.target
