# AI Automated Content Factory — Environment Configuration
# Copy this file to .env and adjust for your setup.
# The factory reads these at startup via os.environ.
#
# Usage:
#   cp .env.example .env
#   source .env   (or use direnv, systemd EnvironmentFile=, etc.)

# ── Root path ─────────────────────────────────────────────────────────────────
# Where the factory stores all data. Defaults to /factory if this is unset
# and /factory exists, otherwise falls back to the repo directory.
# FACTORY_ROOT=/factory

# ── LLM (Writer Agent) ────────────────────────────────────────────────────────
# Ollama model to use for script and prompt generation.
# Run `ollama list` to see installed models.
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Image Generation (Visual Agent) ──────────────────────────────────────────
# ComfyUI API endpoint.
COMFYUI_BASE=http://localhost:8188

# Path to ComfyUI installation directory.
# The visual agent starts and stops ComfyUI automatically to free RAM
# between phases. Set this to wherever you cloned ComfyUI.
COMFYUI_DIR=/home/abrar/ComfyUI

# Name of the Stable Diffusion checkpoint installed in ComfyUI's models/checkpoints/.
# Run: ls ~/.config/comfyui/models/checkpoints/
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly.ckpt

# Image dimensions for generated shots (reduce for faster generation on slow hardware)
VISUAL_IMAGE_WIDTH=768
VISUAL_IMAGE_HEIGHT=512

# Number of diffusion steps (fewer = faster, lower quality; more = slower, higher quality)
VISUAL_STEPS=20

# ── Voice Synthesis (Voice Agent) ─────────────────────────────────────────────
# Path to Piper TTS binary
PIPER_BIN=piper

# Directory containing Piper voice model files (.onnx + .json)
PIPER_MODEL_DIR=/usr/share/piper/voices

# Voice model filename (without path). Download models from:
# https://github.com/rhasspy/piper/releases
PIPER_VOICE=en_US-lessac-medium.onnx

# ── Monitoring ────────────────────────────────────────────────────────────────
# Port for the monitor agent HTTP API and dashboard
FACTORY_MONITOR_PORT=7000

# How often the monitor agent collects metrics (seconds)
FACTORY_MONITOR_TICK=10

# ── Scheduling ────────────────────────────────────────────────────────────────
# How often the foreman scans for new jobs (seconds)
FACTORY_FOREMAN_TICK=3

# Lease duration before a job is considered stalled and reclaimed (seconds)
FACTORY_LEASE_TTL=300

# Maximum jobs allowed in the inbox (0 = unlimited)
FACTORY_INBOX_MAX_DEPTH=50

# ── Resource limits ───────────────────────────────────────────────────────────
# Concurrent job limits per resource class.
# These protect the system on constrained 8GB hardware.
FACTORY_MAX_HEAVY=1     # image generation jobs
FACTORY_MAX_MEDIUM=1    # LLM generation jobs
# light (voice, assembly, monitor) = unlimited

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level for all agents: DEBUG, INFO, WARNING, ERROR
FACTORY_LOG_LEVEL=INFO
